{
  "name": "prostyle-strength-finder",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api": "npm run dev --workspace=@prostyle/api",
    "worker": "npm run dev --workspace=@prostyle/worker",
    "frontend": "npm run dev --workspace=@prostyle/frontend",
    "api:prod": "node apps/api/src/index.js",
    "worker:prod": "node apps/worker/src/index.js",
    "frontend:prod": "node_modules/.bin/next start apps/frontend -p ${FRONTEND_PORT:-3001}",
    "frontend:next": "PORT=${FRONTEND_PORT:-3000} npm run dev:next --workspace=@prostyle/frontend",
    "contracts": "npm run build --workspace=@prostyle/shared-contracts",
    "db:migrate": "node scripts/db/migrate.js apply",
    "db:status": "node scripts/db/migrate.js status",
    "db:create": "node scripts/db/migrate.js create",
    "db:rollback": "node scripts/db/migrate.js rollback",
    "db:checkpoint-local": "node scripts/db/local-data-checkpoint.js",
    "db:reset": "node scripts/db/migrate.js reset",
    "db:reset:safe": "npm run db:reset",
    "db:run-with-restore": "scripts/db/run-with-db-restore.sh",
    "backup:create": "node scripts/backup/create-and-upload.js",
    "backup:restore": "node scripts/backup/restore.js",
    "backup:restore-smoke": "node scripts/backup/restore-smoke.js",
    "queue:recovery-smoke": "node scripts/queue/recovery-smoke.js",
    "ops:checks": "node scripts/ops/operational-checks.js",
    "ops:bootstrap-admin": "node scripts/ops/bootstrap-admin-user.js",
    "ops:logs": "bash scripts/ops/check-prod-logs.sh",
    "ops:db": "bash scripts/ops/inspect-prod-db.sh",
    "ops:db:baselines": "bash scripts/ops/inspect-prod-db.sh baseline-sets",
    "ops:db:suites": "bash scripts/ops/inspect-prod-db.sh suites",
    "ops:db:runs": "bash scripts/ops/inspect-prod-db.sh runs",
    "ops:db:summary": "bash scripts/ops/inspect-prod-db.sh summary",
    "ops:seed-baselines": "bash scripts/ops/seed-prod-baselines.sh",
    "ops:update-nginx": "bash scripts/ops/update-nginx-config.sh",
    "frontend:critical-flow-smoke": "node scripts/frontend/critical-flow-smoke.js",
    "launch:readiness-smoke": "node scripts/launch/readiness-smoke.js",
    "storage:smoke": "node scripts/storage/smoke.js",
    "recommendation:smoke": "node scripts/recommendation/smoke.js",
    "feedback:foundation-check": "node scripts/feedback/foundation-check.js",
    "feedback:service-smoke": "node scripts/feedback/service-smoke.js",
    "feedback:frontend-proxy-smoke": "node scripts/feedback/frontend-proxy-smoke.js",
    "trait:smoke": "node scripts/trait/smoke.js",
    "admin:governance-smoke": "node scripts/admin/governance-smoke.js",
    "admin:moderation-smoke": "node scripts/admin/moderation-smoke.js",
    "admin:prompt-curation-smoke": "node scripts/admin/prompt-curation-smoke.js",
    "admin:approval-policy-smoke": "node scripts/admin/approval-policy-smoke.js",
    "admin:role-management-smoke": "node scripts/admin/role-management-smoke.js",
    "cache:invalidation-smoke": "node scripts/admin/cache-invalidation-smoke.js",
    "admin:frontend-proxy-smoke": "node scripts/admin/frontend-proxy-smoke.js",
    "contributor:essentials-smoke": "node scripts/contributor/essentials-smoke.js",
    "style-dna:tier-validation-smoke": "node scripts/style-dna/tier-validation-smoke.js",
    "style-dna:baseline-smoke": "node scripts/style-dna/baseline-smoke.js",
    "style-dna:baseline-delete-cascade-smoke": "node scripts/style-dna/baseline-delete-cascade-smoke.js",
    "style-dna:seed-canonical-baselines": "node scripts/style-dna/seed-canonical-baselines.js",
    "style-dna:baseline-ar-audit": "node scripts/style-dna/baseline-ar-audit.js",
    "style-dna:prompt-generation-smoke": "node scripts/style-dna/prompt-generation-smoke.js",
    "style-dna:run-smoke": "node scripts/style-dna/run-smoke.js",
    "style-dna:canonicalization-smoke": "node scripts/style-dna/canonicalization-smoke.js",
    "style-dna:canonicalization-semantic-smoke": "node scripts/style-dna/canonicalization-semantic-smoke.js",
    "style-dna:canonical-governance-smoke": "node scripts/style-dna/canonical-governance-smoke.js",
    "style-dna:taxonomy-seed-smoke": "node scripts/style-dna/taxonomy-seed-smoke.js",
    "style-dna:taxonomy-seed-library-smoke": "node scripts/style-dna/taxonomy-seed-library-smoke.js",
    "style-dna:taxonomy-seed-apply": "node scripts/style-dna/apply-taxonomy-seed.js",
    "style-dna:taxonomy-seed-apply-coverage-smoke": "node scripts/style-dna/taxonomy-seed-apply-coverage-smoke.js",
    "style-dna:taxonomy-seed-diff": "node scripts/style-dna/taxonomy-seed-diff.js",
    "style-dna:taxonomy-seed-diff-smoke": "node scripts/style-dna/taxonomy-seed-diff-smoke.js",
    "style-dna:taxonomy-seed-coverage": "node scripts/style-dna/taxonomy-seed-coverage.js",
    "style-dna:taxonomy-seed-coverage-smoke": "node scripts/style-dna/taxonomy-seed-coverage-smoke.js",
    "style-dna:taxonomy-seed-v2-rollout-smoke": "node scripts/style-dna/taxonomy-seed-v2-rollout-smoke.js",
    "style-dna:taxonomy-seed-rollout-artifacts": "node scripts/style-dna/taxonomy-seed-rollout-artifacts.js",
    "style-dna:taxonomy-seed-rollout-artifacts-smoke": "node scripts/style-dna/taxonomy-seed-rollout-artifacts-smoke.js",
    "style-dna:taxonomy-seed-rollout-artifacts-index": "node scripts/style-dna/taxonomy-seed-rollout-artifacts-index.js",
    "style-dna:taxonomy-seed-rollout-artifacts-prune": "node scripts/style-dna/taxonomy-seed-rollout-artifacts-prune.js",
    "style-dna:taxonomy-seed-rollout-artifacts-export": "node scripts/style-dna/taxonomy-seed-rollout-artifacts-export.js",
    "style-dna:taxonomy-seed-rollout-artifacts-upload": "node scripts/style-dna/taxonomy-seed-rollout-artifacts-upload.js",
    "style-dna:taxonomy-seed-rollout-artifacts-publish": "node scripts/style-dna/taxonomy-seed-rollout-artifacts-publish.js",
    "style-dna:taxonomy-seed-rollout-artifacts-index-prune-smoke": "node scripts/style-dna/taxonomy-seed-rollout-artifacts-index-prune-smoke.js",
    "style-dna:taxonomy-seed-rollout-artifacts-export-smoke": "node scripts/style-dna/taxonomy-seed-rollout-artifacts-export-smoke.js",
    "style-dna:taxonomy-seed-rollout-artifacts-upload-smoke": "node scripts/style-dna/taxonomy-seed-rollout-artifacts-upload-smoke.js",
    "style-dna:taxonomy-seed-rollout-artifacts-upload-ci": "node scripts/style-dna/taxonomy-seed-rollout-artifacts-upload-ci.js",
    "style-dna:taxonomy-seed-evidence-governance-check": "node scripts/style-dna/taxonomy-seed-evidence-governance-check.js",
    "style-dna:discovery-review-replay-smoke": "node scripts/style-dna/discovery-review-replay-smoke.js",
    "style-dna:schema-failure-smoke": "node scripts/style-dna/schema-failure-smoke.js",
    "style-dna:smokes:with-restore": "scripts/db/run-with-db-restore.sh /bin/zsh -lc \"npm run style-dna:tier-validation-smoke && npm run style-dna:baseline-smoke && npm run style-dna:baseline-delete-cascade-smoke && npm run style-dna:prompt-generation-smoke && npm run style-dna:canonicalization-smoke && npm run style-dna:run-smoke && npm run style-dna:schema-failure-smoke\"",
    "governance:verify": "node scripts/governance/verify-freshness.js",
    "governance:verify:prod": "node scripts/governance/verify-freshness.js --env prod",
    "e2e:playwright": "/bin/zsh -lc \"set -a && source .env.local && set +a && node tests/playwright/setup/seed-style-dna-run-ops.js && playwright test -c playwright.config.ts\"",
    "e2e:playwright:reuse": "/bin/zsh -lc \"set -a && source .env.local && set +a && node tests/playwright/setup/seed-style-dna-run-ops.js && PLAYWRIGHT_USE_EXISTING_SERVER=1 playwright test -c playwright.config.ts\"",
    "e2e:playwright:headed": "/bin/zsh -lc \"set -a && source .env.local && set +a && node tests/playwright/setup/seed-style-dna-run-ops.js && playwright test -c playwright.config.ts --headed\"",
    "e2e:playwright:install": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "playwright": "^1.55.0"
  }
}
