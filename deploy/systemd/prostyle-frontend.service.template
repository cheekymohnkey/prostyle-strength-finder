[Unit]
Description=Prostyle Frontend
After=network.target prostyle-api.service

[Service]
Type=simple
User=__RUN_USER__
WorkingDirectory=__APP_DIR__
EnvironmentFile=__ENV_FILE__
Environment=PORT=3001
ExecStart=__APP_DIR__/node_modules/.bin/next start apps/frontend -p 3001
Restart=always
RestartSec=5
StandardOutput=append:/var/log/prostyle/frontend.log
StandardError=append:/var/log/prostyle/frontend.log

[Install]
WantedBy=multi-user.target
